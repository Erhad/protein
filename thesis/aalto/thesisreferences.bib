  urldate = {2026-04-25},
  abstract = {ABSTRACT                        Antibody-drug conjugates (ADCs) have emerged as promising therapeutics for cancer treatment; however, their effectiveness has been limited by single antigen targeting, potentially leading to resistance mechanisms triggered by tumor compensatory pathways or reduced expression of the target protein. Here, we present antibody-ADC click, an approach that harnesses bioorthogonal click chemistry for             in vivo             dual receptor targeting, irrespective of the levels of the tumor’s expression of the ADC-targeting antigen. Antibody-ADC click enables targeting heterogeneity and enhances antibody internalization and drug delivery inside cancer cells, resulting in potent toxicity. We conjugated antibodies and ADCs to the bioorthogonal click moieties tetrazine (Tz) and trans-cyclooctene (TCO). Through sequential antibody administration in living biological systems, we achieved dual receptor targeting by             in vivo             clicking of antibody-TCO with antibody-Tz. We show that the clicked antibody therapy outperformed conventional ADC monotherapy or antibody combinations in preclinical models mimicking ADC-eligible, ADC-resistant, and ADC-ineligible tumors. Antibody-ADC click enables             in vivo             dual-antigen targeting without extensive antibody bioengineering, sustains tumor treatment, and enhances antibody-mediated cytotoxicity.},
  langid = {english},
  pubstate = {prepublished},
  file = {/Users/aleksanderheino/Zotero/storage/GS2JVX7Z/Panikar et al. - 2023 - In Vivo Biorthogonal Antibody Click for Dual Targeting and Augmented Efficacy in Cancer Treatment.pdf}
}

@online{renProximalExplorationModelguided2022,
