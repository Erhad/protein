	keywords = {Computer Science - Machine Learning, Statistics - Machine Learning},
	file = {PDF:/Users/aleksanderheino/Zotero/storage/TIIGJINJ/Snoek et al. - 2012 - Practical Bayesian Optimization of Machine Learning Algorithms.pdf:application/pdf},
}

